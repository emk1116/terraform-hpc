# =============================================================================
# Titan HPC — cost-optimized example tfvars for $100 AWS-credit testing
#
# Pure HPC: head node (slurmctld) + login node + workflow node + autoscaled
# GPU compute + FSx + Aurora (for slurmdbd) + S3 + ECR.
#
# No UI, no ALB. Users `aws ssm start-session` into the login node and
# run sbatch / snakemake directly.
#
# Always-on baseline ~$8.50/day. A 4-hour test session ≈ $1.50-2 + compute.
# =============================================================================

# --- Identity ---
team_name  = "titan"
env        = "non-prod"
aws_region = "us-east-1"
primary_az = "us-east-1f"

# --- Network ---
vpc_cidr         = "10.20.0.0/16"
ssh_allowed_cidr = "203.0.113.5/32" # REPLACE with your /32. `curl ifconfig.me`

# --- Login + workflow nodes ---
enable_login_node           = true
login_node_instance_type    = "t3.small"
enable_workflow_node        = true
workflow_node_instance_type = "t3.small"

# --- Head node (control plane, not user-facing) ---
head_node_instance_type = "t3.small"

# --- Compute / GPU (cheap families only for $100-budget testing) ---
gpu_families_enabled = ["t4", "l4"]
gpu_max_nodes = {
  t4      = 4
  a10g    = 0
  l4      = 2
  a100    = 0
  h100-1x = 0
  h100-8x = 0
}
h100_fallback_azs = []

# --- Storage ---
fsx_storage_capacity_gib = 1200 # SCRATCH_2 minimum
s3_bucket_force_destroy  = true

# --- Database (slurmdbd accounting only) ---
aurora_min_capacity_acu      = 0.5
aurora_max_capacity_acu      = 1
aurora_backup_retention_days = 1

# --- Cost guardrails ---
admin_email             = "admin@example.com" # REPLACE — receives Budgets alerts
team_monthly_budget_usd = 100
